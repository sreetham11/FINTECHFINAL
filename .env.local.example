# ─────────────────────────────────────────────────────────────
# Environment variables for nets-quest (FINTECHFINAL)
# Copy this file to .env.local and fill in the values.
# Next.js + Prisma load from .env.local (see prisma.config.ts).
# ─────────────────────────────────────────────────────────────

# ── Database (Postgres / Supabase) ──
# Used by Prisma via the pg adapter (src/lib/prisma.ts) and prisma.config.ts
DATABASE_URL=

# ── Supabase (server-side) ──
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase (client-side, exposed to browser) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Anthropic / Claude (AI features: chat coach, receipt & voice parsing, memories) ──
ANTHROPIC_API_KEY=

# ── Groq (AI memory one-liner captions — /api/generate-caption) ──
GROQ_API_KEY=

# ── Resend (transactional email — settlement reminder cron) ──
RESEND_API_KEY=

# ── Cron auth (protects /api/cron/* via middleware) ──
CRON_SECRET=

# ── Google Maps (overseas NETS map component) ──
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── App base URL (used to build links in emails) ──
# e.g. http://localhost:3000 for local dev
NEXT_PUBLIC_APP_URL=
